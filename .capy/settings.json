{
  "$schema": "https://capy.ai/settings.schema.json",
  "project": {
    "name": "Windburn",
    "description": "Local-first Remote Workhorse control surface for Superconductor, Fusion Bridge, Superruntime, and remote proof lanes.",
    "sourceOfTruth": [
      "git",
      "github",
      "ci",
      "review-comments"
    ],
    "supportingContext": [
      "capy-ui",
      "sanity",
      "superconductor",
      "fusion-bridge",
      "superruntime"
    ]
  },
  "mcpServers": {
    "Sanity": {
      "type": "http",
      "url": "https://mcp.sanity.io",
      "description": "Sanitized shared context registry for Windburn roles, skills, proof lanes, evidence pointers, decisions, handoffs, and Capy checks. Authorize through Capy/Sanity OAuth when prompted; do not store bearer tokens here."
    }
  },
  "contextPolicy": {
    "authoritativeEvidence": [
      "git diff",
      "git commits",
      "github pull requests",
      "github review comments",
      "ci checks",
      "local verification commands"
    ],
    "supportingEvidence": [
      "Capy UI",
      "Sanity context records",
      "Superconductor summaries",
      "Fusion Bridge notes",
      "agent self-reports"
    ],
    "forbiddenData": [
      "api keys",
      "oauth material",
      "bearer tokens",
      "cookies",
      "passwords",
      "raw request payloads",
      "raw response payloads",
      "raw transcripts",
      "private screenshots",
      "private browser traces",
      "unrelated private UI",
      "raw public hosts",
      "raw public IPs",
      "local absolute paths",
      "SSH or tmux targets",
      "credential paths",
      "raw provider tokens",
      "raw auth payloads"
    ]
  },
  "closeout": {
    "requiredEvidence": [
      "files changed",
      "verification commands",
      "residual risk",
      "next action",
      "PASS | FLAG | BLOCK verdict"
    ]
  },
  "hooks": {
    "setup": [
      {
        "command": "cargo fetch",
        "agents": [
          "build"
        ]
      }
    ],
    "terminals": [
      {
        "name": "fusion-chat-bridge",
        "command": "scripts/fusion-chat-bridge.sh",
        "readonly": true
      }
    ],
    "previews": [
      {
        "name": "fusion-chat",
        "port": 5178
      }
    ]
  }
}
